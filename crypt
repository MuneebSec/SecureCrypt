#!/bin/bash

# Color definitions
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
YELLOW=$(tput setaf 3)
NC=$(tput sgr0)

# Check for required system dependencies
check_system_deps() {
    local missing=()
    for cmd in python3 openssl tar; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done

    if [ ${#missing[@]} -gt 0 ]; then
        echo "${YELLOW}Missing system dependencies: ${missing[*]}${NC}" >&2
        echo "${YELLOW}Attempting to install on Ubuntu/Debian/Kali...${NC}" >&2
        if ! sudo apt update; then
            echo "${RED}Failed to update package list${NC}" >&2
            exit 1
        fi
        for cmd in "${missing[@]}"; do
            if ! sudo apt install -y "$cmd"; then
                echo "${RED}Failed to install $cmd${NC}" >&2
                exit 1
            fi
        done
        echo "${GREEN}System dependencies installed successfully${NC}" >&2
    fi
}

# Main execution
check_system_deps

# Run the Python script with all provided arguments
python3 - "$@" <<'EOF'
#!/usr/bin/env python3
"""
crypt.py 
— single-line smooth progress encrypt/decrypt (archive+encrypt and decrypt+extract merged)
Version 2.4.2 (Fixed extraction path, password prompt alignment, and size formatting)
"""
import os
import sys
import time
import getpass
import shutil
import tarfile
import tempfile
import subprocess
import argparse
import threading
from pathlib import Path

VERSION = "2.4.2"
SPINNER = ['-', '\\', '|', '/']

class Colors:
    RED = "\033[31m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    BLUE = "\033[34m"
    NC = "\033[0m"

# ---------- utilities ----------
def format_size(b):
    for unit in ('B','KB','MB','GB','TB'):
        if b < 1024.0:
            return f"{b:.2f} {unit}"
        b /= 1024.0
    return f"{b:.2f} PB"

def safe_input_password(prompt, show):
    if show:
        sys.stderr.write(prompt)
        sys.stderr.flush()
        try:
            with open('/dev/tty') as tty_file:
                return tty_file.readline().strip()
        except Exception:
            return getpass.getpass("")
    else:
        # Custom input handler to show asterisks across multiple platforms
        sys.stderr.write(prompt)
        sys.stderr.flush()
        pwd = ""
        try:
            import msvcrt
            while True:
                ch = msvcrt.getch()
                if ch in (b'\r', b'\n'):
                    sys.stderr.write('\r\n')
                    sys.stderr.flush()
                    break
                elif ch == b'\x08':
                    if len(pwd) > 0:
                        pwd = pwd[:-1]
                        sys.stderr.write('\b \b')
                        sys.stderr.flush()
                elif ch == b'\x03':
                    raise KeyboardInterrupt
                else:
                    pwd += ch.decode('utf-8', 'ignore')
                    sys.stderr.write('*')
                    sys.stderr.flush()
            return pwd
        except ImportError:
            try:
                import termios, tty
                fd = os.open('/dev/tty', os.O_RDWR)
                old_settings = termios.tcgetattr(fd)
                try:
                    tty.setraw(fd)
                    while True:
                        ch = os.read(fd, 1).decode('utf-8')
                        if ch in ('\n', '\r'):
                            sys.stderr.write('\r\n')
                            sys.stderr.flush()
                            break
                        elif ch in ('\b', '\x7f'):
                            if len(pwd) > 0:
                                pwd = pwd[:-1]
                                sys.stderr.write('\b \b')
                                sys.stderr.flush()
                        elif ch == '\x03':
                            raise KeyboardInterrupt
                        else:
                            pwd += ch
                            sys.stderr.write('*')
                            sys.stderr.flush()
                finally:
                    termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
                    os.close(fd)
                return pwd
            except Exception:
                # Absolute fallback if /dev/tty fails
                return getpass.getpass("")

def print_line(stage, pct, spinner=' ', quiet=False):
    if quiet:
        return
    pct = max(0.0, min(100.0, pct))
    width = 36
    filled = int((pct/100.0) * width)
    bar = '█'*filled + '-'*(width - filled)
    sys.stderr.write(f"\r{Colors.YELLOW}[{stage}] |{bar}| {pct:6.2f}% {spinner}{Colors.NC}")
    sys.stderr.flush()

def qprint(msg, quiet=False, file=sys.stderr):
    if not quiet:
        print(msg, file=file)

# ---------- Custom Help Menu ----------
def print_help():
    print(f"\n{Colors.GREEN}======================================================{Colors.NC}")
    print(f"{Colors.YELLOW}         Secure File Encryptor/Decryptor v{VERSION}{Colors.NC}")
